{
  "name": "anti-blunder-club",
  "dockerComposeFile": "docker-compose.devcontainer.yml",
  "service": "app",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "workspaceFolder": "/workspaces/anti-blunder-club",
  "forwardPorts": [5173],
  "containerEnv": {
    "DEVCONTAINER": "true",
    "ANTHROPIC_AUTH_TOKEN": "${localEnv:ANTHROPIC_AUTH_TOKEN}",
    "ANTHROPIC_BASE_URL": "${localEnv:ANTHROPIC_BASE_URL}"
  },
  "initializeCommand": [
    "node",
    "-e",
    "const fs=require('fs'),p=require('path'),os=require('os');const f=p.join(os.homedir(),'.gitconfig');if(!fs.existsSync(f))fs.closeSync(fs.openSync(f,'a'));"
  ],
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.gitconfig,target=/home/node/.gitconfig,type=bind,consistency=cached",
    "source=devcontainer-bashhistory,target=/commandhistory,type=volume"
  ],
  "postCreateCommand": "mkdir -p ~/.claude && cp .devcontainer/claude-settings.json ~/.claude/settings.json && npm install -g @anthropic-ai/claude-code && git config --global --add safe.directory /workspaces/anti-blunder-club",
  "postStartCommand": "git fetch --all --prune 2>/dev/null || true",
  "remoteUser": "node",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "Prisma.prisma",
        "eamodio.gitlens",
        "github.copilot",
        "github.copilot-chat",
        "anthropics.claude-code",
        "yoavbls.pretty-ts-errors",
        "bradlc.vscode-tailwindcss",
        "vitest.explorer",
        "ckolkman.vscode-postgres",
        "mhutchie.git-graph",
        "ms-azuretools.vscode-docker",
        "DavidAnson.vscode-markdownlint",
        "streetsidesoftware.code-spell-checker"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "eslint.validate": [
          "javascript",
          "javascriptreact",
          "typescript",
          "typescriptreact"
        ],
        "typescript.tsdk": "frontend/node_modules/typescript/lib",
        "typescript.enablePromptUseWorkspaceTsdk": true,
        "tailwindCSS.experimental.classRegex": [
          ["cn\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
        ],
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.scrollback": 50000,
        "github.copilot.chat.commitMessageGeneration.instructions": [
          {
            "text": "Use Angular Conventional Commits format: <type>(<scope>): <short summary>\n\nTypes: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert.\nScope is optional but encouraged.\nSummary must be lowercase, imperative mood, no period at the end, max 72 characters.\nAdd a body after a blank line if the change needs explanation (wrap at 72 chars).\nAdd BREAKING CHANGE: in the footer for breaking changes."
          }
        ],
        "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
        "[typescriptreact]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        }
      }
    }
  }
}
